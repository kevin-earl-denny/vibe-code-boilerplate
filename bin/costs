#!/usr/bin/env bash
#
# Costs - Cloud service cost tracking CLI
#
# Commands:
#   costs summary          - Show cost summary across providers
#   costs summary --month  - Show historical month
#   costs summary --budget - Show budget vs actual
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

VENV_DIR="$REPO_ROOT/.vibe/.venv"

# Ensure venv exists (run vibe once to set it up)
if [[ ! -d "$VENV_DIR" ]]; then
    echo "Virtual environment not found. Running setup..."
    "$SCRIPT_DIR/vibe" doctor > /dev/null 2>&1 || true
fi

if [[ ! -d "$VENV_DIR" ]]; then
    echo "Error: Failed to create virtual environment. Run 'bin/vibe' first." >&2
    exit 1
fi

# Activate venv and run
source "$VENV_DIR/bin/activate"
cd "$REPO_ROOT"
python -m lib.vibe.cli.costs "$@"
